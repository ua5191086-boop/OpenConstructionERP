# OpenConstructionERP — Quick Start
# Environment variables
# Copy to .env and fill in secrets

# PostgreSQL
POSTGRES_DB=oce
POSTGRES_USER=oce
POSTGRES_PASSWORD=oce_secret_2026

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=oce
MINIO_ROOT_PASSWORD=oce_secret_2026
MINIO_DEFAULT_BUCKET=oce-documents

# Redis
REDIS_PASSWORD=oce_secret_2026

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=oce_secret_2026
KC_DB_PASSWORD=oce_secret_2026

# Kafka
KAFKA_BROKER_ID=1

# OpenSearch
OPENSEARCH_INITIAL_ADMIN_PASSWORD=oce_secret_2026

# ClickHouse
CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT=1
CLICKHOUSE_PASSWORD=oce_secret_2026

# JWT Secret (change in production!)
JWT_SECRET=oce-jwt-secret-change-in-production-2026

# Encryption key for sensitive fields
ENCRYPTION_KEY=oce-encryption-key-32bytes-2026!!!!!
